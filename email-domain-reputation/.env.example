# Copy this file to .env and fill in real values. .env is gitignored --
# never commit it. See SKILL.md for where to get each key.

# emailrep.io -- free tier: 250 queries/month, 10/day (rolling 24h window)
EMAILREP_API_KEY=your_emailrep_api_key_here
# Any identifying string is fine -- EmailRep just wants a stable User-Agent.
EMAILREP_USER_AGENT=your-app-name-v1

# abstractapi.com Email Validation
ABSTRACTAPI_API_KEY=your_abstractapi_api_key_here
